{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": ["config:best-practices"],
  "schedule": ["before 8am on wednesday"],
  "packageRules": [
    {
      "matchManagers": ["dockerfile", "mise", "cargo"],
      "matchFileNames": ["benches/**", "fuzz/**", "Dockerfile"],
      "groupName": "benches",
      "matchUpdateTypes": ["patch", "minor", "digest"],
      "automerge": true
    },
    {
      "matchManagers": ["dockerfile", "mise", "cargo"],
      "matchFileNames": [
        "xtask/bench/**",
        "benches/**",
        "fuzz/**",
        "Dockerfile"
      ],
      "rangeStrategy": "pin"
    },
    {
      "matchManagers": ["dockerfile", "mise", "cargo"],
      "matchFileNames": ["benches/**", "fuzz/**", "Dockerfile"],
      "groupName": "benches (major)",
      "matchUpdateTypes": ["major"]
    },
    {
      "matchManagers": ["cargo"],
      "matchFileNames": ["crates/**/Cargo.toml"],
      "rangeStrategy": "update-lockfile"
    },
    {
      "matchManagers": ["cargo"],
      "matchFileNames": ["Cargo.toml"],
      "matchDepTypes": ["workspace.dependencies"],
      "rangeStrategy": "update-lockfile"
    },
    {
      "matchManagers": ["cargo"],
      "groupName": "rust deps (minor + patch)",
      "matchUpdateTypes": ["patch", "minor"]
    },
    {
      "matchManagers": ["cargo", "npm"],
      "matchDepTypes": ["devDependencies"],
      "groupName": "dev deps (minor + patch)",
      "matchUpdateTypes": ["patch", "minor"],
      "automerge": true
    },
    {
      "matchManagers": ["cargo"],
      "groupName": "rust deps (major)",
      "matchUpdateTypes": ["major"]
    },
    {
      "matchFileNames": ["rust-toolchain.toml"],
      "groupName": "rust toolchain",
      "schedule": ["before 5am on the first day of the month"],
      "automerge": true
    },
    {
      "matchManagers": ["npm"],
      "matchDepTypes": ["dependencies"],
      "groupName": "npm runtime deps (minor + patch)",
      "matchUpdateTypes": ["patch", "minor"]
    },
    {
      "matchManagers": ["npm"],
      "matchDepTypes": ["dependencies"],
      "groupName": "npm runtime deps (major)",
      "matchUpdateTypes": ["major"],
      "dependencyDashboardApproval": true
    },
    {
      "matchManagers": ["npm"],
      "matchDepTypes": ["engines"],
      "matchPackageNames": ["vscode"],
      "enabled": false
    },
    {
      "matchManagers": ["npm"],
      "matchPackageNames": ["@types/vscode"],
      "enabled": false
    },
    {
      "matchManagers": ["npm"],
      "matchPackageNames": ["@types/node"],
      "matchUpdateTypes": ["major"],
      "enabled": false
    },
    {
      "matchManagers": ["github-actions"],
      "groupName": "github actions",
      "matchUpdateTypes": ["patch", "minor", "digest"],
      "automerge": true,
      "minimumReleaseAge": "14 days",
      "prCreation": "not-pending"
    },
    {
      "matchManagers": ["git-submodules"],
      "automerge": true
    },
    {
      "matchManagers": ["mise"],
      "matchFileNames": [
        ".config/mise/config.toml",
        ".config/mise/conf.d/*.toml"
      ],
      "matchUpdateTypes": ["patch", "minor"],
      "groupName": "mise dev tools (patch + minor)",
      "automerge": true,
      "minimumReleaseAge": "3 days"
    },
    {
      "matchPackageNames": ["libfuzzer-sys", "cargo:cargo-fuzz"],
      "groupName": "cargo-fuzz",
      "automerge": true
    },
    {
      "matchPackageNames": ["cargo-insta", "cargo:cargo-insta"],
      "groupName": "cargo-insta",
      "automerge": true
    },
    {
      "matchPackageNames": ["jdx/hk", "aqua:jdx/hk"],
      "groupName": "hk",
      "automerge": true,
      "minimumReleaseAge": "3 days"
    },
    {
      "matchPackageNames": [
        "codspeed-criterion-compat",
        "cargo:cargo-codspeed",
        "cargo:cargo-criterion"
      ],
      "groupName": "cargo-codspeed",
      "automerge": true
    },
    {
      "matchPackageNames": ["gungraun", "cargo:gungraun-runner"],
      "groupName": "gungraun",
      "automerge": true
    },
    {
      "matchManagers": ["mise"],
      "matchFileNames": [
        ".config/mise/config.toml",
        ".config/mise/conf.d/*.toml"
      ],
      "matchPackageNames": [
        "cargo:cargo-dist",
        "cargo:release-plz",
        "cargo:cargo-release"
      ],
      "groupName": "mise release tools",
      "dependencyDashboardApproval": true
    },
    {
      "matchPackageNames": ["pnpm", "aqua:pnpm/pnpm"],
      "groupName": "pnpm",
      "automerge": true
    },
    {
      "matchPackageNames": [
        "ghcr.io/renovatebot/renovate",
        "renovate",
        "npm:renovate"
      ],
      "groupName": "renovate tooling"
    }
  ],
  "ignorePaths": [
    ".github/workflows/jjpwrgem-v-release.yml",
    "npm-packages/jjpwrgem/package.json"
  ],
  "npm": {
    "managerFilePatterns": ["/(^|/)package\\.template\\.json$/"]
  },
  "customManagers": [
    {
      "customType": "regex",
      "description": "Update renovate version in renovate workflow",
      "managerFilePatterns": ["/.github/workflows/renovate\\.yml$/"],
      "matchStrings": [
        "RENOVATE_VERSION: (?<currentValue>[^\\s]+) # renovate: datasource=(?<datasource>[^\\s]+) depName=(?<depName>[^\\s]+)"
      ]
    },
    {
      "customType": "regex",
      "description": "Track cargo-fuzz version pinned in install-fuzz task (not in [tools] to avoid auto-install)",
      "managerFilePatterns": ["/^\\.config/mise/conf\\.d/fuzz\\.toml$/"],
      "matchStrings": ["cargo:cargo-fuzz@(?<currentValue>[\\d.]+)"],
      "depNameTemplate": "cargo-fuzz",
      "packageNameTemplate": "cargo-fuzz",
      "datasourceTemplate": "crate"
    },
    {
      "customType": "regex",
      "description": "Bump hk's pkl amends URL in hk.pkl alongside the mise hk tool",
      "managerFilePatterns": ["/^\\.config/hk\\.pkl$/"],
      "matchStrings": [
        "github\\.com/jdx/hk/releases/download/v(?<currentValue>\\d+\\.\\d+\\.\\d+)/",
        "/hk@(?<currentValue>\\d+\\.\\d+\\.\\d+)#"
      ],
      "depNameTemplate": "jdx/hk",
      "packageNameTemplate": "jdx/hk",
      "datasourceTemplate": "github-releases",
      "extractVersionTemplate": "^v?(?<version>.*)$"
    }
  ]
}
