{
  "glspc.server.command": "tracey",
  "glspc.server.commandArguments": ["lsp"],
  "glspc.server.languageId": [
    "rust",
    "typescript",
    "typescriptreact",
    "javascript",
    "javascriptreact",
    "python",
    "go",
    "swift",
    "java",
    "markdown"
  ],
  "files.watcherExclude": {
    "tests/conformance/JSONTestSuite": true
  },
  "files.readonlyInclude": {
    "tests/conformance/JSONTestSuite": true
  },
  "coverage-gutters.coverageBaseDir": "./target/llvm-cov",
  "rust-analyzer.cargo.features": ["jjpwrgem-parse/serde"]
}
