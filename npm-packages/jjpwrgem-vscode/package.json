{
  "name": "jjpwrgem-vscode",
  "displayName": "jjpwrgem-vscode",
  "version": "0.0.1",
  "description": "format json with jjpwrgem!",
  "categories": [
    "Other"
  ],
  "publisher": "20jasper",
  "type": "commonjs",
  "main": "./dist/extension.js",
  "scripts": {
    "vscode:prepublish": "pnpm run package",
    "compile": "pnpm run check-types && node esbuild.js",
    "watch": "npm-run-all -p watch:*",
    "watch:esbuild": "node esbuild.js --watch",
    "watch:tsgo": "tsgo --watch --project tsconfig.json",
    "package": "pnpm run check-types && node esbuild.js --production",
    "compile-tests": "tsgo -p . --outDir out",
    "watch-tests": "tsgo -p . -w --outDir out",
    "pretest": "pnpm run compile-tests && pnpm run compile",
    "check-types": "tsgo --noEmit",
    "test": "vscode-test"
  },
  "dependencies": {
    "vscode-languageclient": "^9.0.1"
  },
  "devDependencies": {
    "@types/mocha": "^10.0.10",
    "@types/node": "22.x",
    "@types/vscode": "^1.107.0",
    "@vscode/test-cli": "^0.0.12",
    "@vscode/test-electron": "^2.5.2",
    "esbuild": "^0.27.1",
    "npm-run-all": "^4.1.5",
    "typescript": "npm:@typescript/native-preview@7.0.0-dev.20260523.1"
  },
  "contributes": {},
  "activationEvents": [
    "onLanguage:json"
  ],
  "engines": {
    "vscode": "^1.107.0"
  }
}
