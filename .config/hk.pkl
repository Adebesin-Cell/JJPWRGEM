amends "package://github.com/jdx/hk/releases/download/v1.48.0/hk@1.48.0#/Config.pkl"
import "package://github.com/jdx/hk/releases/download/v1.48.0/hk@1.48.0#/Builtins.pkl"

// Steps that mutate files. Run in pre-commit (with stash) and on `hk fix`.
local fix_steps = new Mapping<String, Step> {
  ["diet"] {
    fix = "mise run diet"
    stage = List("crates/**/Cargo.toml", "Cargo.toml")
  }
  ["format"] {
    glob = List("**/*.{rs,md,toml,yml,ts,js,json}")
    fix = "mise run format"
  }
  ["readmes"] {
    glob = List("xtask/templates/**", "xtask/src/template.rs", "crates/bytes2chars/src/**", "benches/docker/output/*.md", "benches/output/*.md")
    fix = "mise run readmes"
    stage = List("**/*.md", "*.md")
  }
}

// Read-only steps. Run on pre-push and `hk check`.
local check_steps = new Mapping<String, Step> {
  ["renovate-check"] {
    glob = List(".github/renovate.json")
    check = "mise run renovate-check"
  }
  ["format-check"] {
    check = "mise run format-check"
  }
  ["lint"] {
    glob = List("**/*.rs")
    check = "mise run lint"
  }
  ["package-check"] {
    glob = List("**/*.rs", "**/Cargo.toml", "axolotl.txt", "tests/integration/snapshots/*.snap")
    check = "mise run package-check"
  }
  ["cargo-shear"] {
    check = "mise run cargo-shear"
  }
  ["cargo-deny"] {
    check = "mise run deny"
  }
  ["dist-plan"] {
    check = "mise run dist-plan"
  }
  ["readmes-check"] {
    check = "mise run readmes-check"
  }
  ["shellcheck"] {
    glob = List("**/*.sh", "**/*.bash")
    check = "mise run shellcheck"
  }
  ["typos"] {
    check = "mise run typos"
  }
  ["tracey-check"] {
    check = "mise run tracey-check"
  }
  ["test"] {
    glob = List("**/*.rs")
    check = "mise run test"
  }
  ["check-types"] {
    glob = List("**/*.ts")
    check = "pnpm --filter jjpwrgem-vscode run check-types"
  }
  ["oxlint"] {
    glob = List("**/*.ts")
    check = "mise run oxlint"
  }
  ["knip"] {
    glob = List("npm-packages/jjpwrgem-vscode/**")
    check = "mise run knip"
  }
  ["vsce-pack-check"] {
    glob = List("npm-packages/jjpwrgem-vscode/**")
    check = "mise run vsce-pack-check"
  }
}

// Sync mise tools whenever mise config files change in a checkout/merge.
local sync_mise = new Mapping<String, Step> {
  ["mise-install"] {
    glob = List(".config/mise/config.toml", ".config/mise/conf.d/*.toml", "benches/mise.toml", "benches/docker/mise.toml", "rust-toolchain.toml")
    check = "mise install --locked --quiet"
  }
}

// Validate the commit message format against conventional-commits.
local commit_msg_steps = new Mapping<String, Step> {
  ["committed"] {
    check = "mise run committed {{commit_msg_file}}"
  }
}

hooks {
  ["pre-commit"] {
    fix = true
    stash = "git"
    steps = fix_steps
  }
  ["pre-push"] {
    steps = check_steps
  }
  ["fix"] {
    fix = true
    steps = fix_steps
  }
  ["check"] {
    steps = check_steps
  }
  ["post-merge"] {
    steps = sync_mise
  }
  ["post-checkout"] {
    steps = sync_mise
  }
  ["commit-msg"] {
    steps = commit_msg_steps
  }
}
